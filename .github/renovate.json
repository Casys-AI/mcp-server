{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(chore)"
  ],
  "schedule": [
    "before 9am on monday"
  ],
  "timezone": "Europe/Paris",
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Group all @casys/* packages into a single PR so cross-package bumps (e.g., mcp-server affecting mcp-compose or mcp-bridge) are reviewed together.",
      "matchPackagePatterns": [
        "^@casys/"
      ],
      "groupName": "@casys packages",
      "commitMessageTopic": "@casys workspace packages"
    },
    {
      "description": "Group Deno standard library (@std/*) bumps into one PR to reduce noise.",
      "matchPackagePatterns": [
        "^@std/"
      ],
      "groupName": "@std packages",
      "commitMessageTopic": "@std (Deno stdlib)"
    },
    {
      "description": "Group @modelcontextprotocol/sdk bumps separately — this is the MCP SDK upstream, breaking changes require manual review.",
      "matchPackageNames": [
        "@modelcontextprotocol/sdk"
      ],
      "labels": [
        "mcp-sdk"
      ]
    }
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "labels": [
    "dependencies"
  ]
}
