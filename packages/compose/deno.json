{
  "name": "@casys/mcp-compose",
  "version": "0.3.0",
  "exports": {
    ".": "./mod.ts",
    "./core": "./src/core/mod.ts",
    "./sdk": "./src/sdk/mod.ts",
    "./host": "./src/host/mod.ts",
    "./runtime": "./src/runtime/mod.ts",
    "./deploy": "./src/deploy/mod.ts"
  },
  "publish": {
    "include": ["mod.ts", "src/**/*.ts", "README.md", "LICENSE"],
    "exclude": ["**/*_test.ts", "tests/", "_reference/"]
  },
  "tasks": {
    "test": "deno test --allow-read --allow-write --allow-run --allow-net --allow-env src/ stubs/tests/",
    "test:unit": "deno test --allow-read --allow-write src/",
    "test:stubs": "deno test --allow-read --allow-write --allow-run --allow-net --allow-env stubs/tests/",
    "test:watch": "deno test --watch --allow-read --allow-write src/",
    "demo": "deno run --allow-all stubs/demo.ts",
    "check": "deno check mod.ts",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.0",
    "@casys/mcp-server": "../mcp-server/mod.ts",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.27.0"
    "ajv": "npm:ajv@^8.17.1",
    "hono": "npm:hono@^4",
    "hono/cors": "npm:hono@^4/cors",
    "jose": "npm:jose@^6.0.0",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0"
  }
}
