{
  "name": "@casys/mcp-view",
  "version": "0.3.0",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts"
  },
  "publish": {
    "include": ["mod.ts", "src/**/*.ts", "src/**/*.md", "README.md", "LICENSE"],
    "exclude": ["**/*_test.ts"]
  },
  "tasks": {
    "build:npm": "deno run -A scripts/build-npm.ts",
    "test": "deno test --allow-read src/",
    "check": "deno check mod.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "changelog:draft": "git -C ../.. cliff --config cliff.toml --tag-pattern 'view-v.*' --include-path 'packages/view/**' --unreleased",
    "release:check": "deno task check && deno task lint && deno task test",
    "release:tag": "deno run -A ../../scripts/release-tag.ts view"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2
  },
  "lint": {
    "exclude": ["dist-node", "examples"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.ns", "deno.window", "dom", "dom.iterable", "dom.asynciterable", "esnext"]
  },
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@^0.41",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.29.0",
    "@modelcontextprotocol/ext-apps": "npm:@modelcontextprotocol/ext-apps@^1.7.1"
  }
}
